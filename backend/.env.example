# ====================================================================
# JG-FIT backend — variaveis de ambiente
# Copie para .env e preencha com os valores reais (o .env NAO vai pro git)
# ====================================================================

# App
# 3000 fica para o frontend (Next.js). Backend na 3333 para nao conflitar.
PORT=3333
NODE_ENV=development

# E-mail tratado como PROFESSOR no primeiro login (os demais viram ALUNO)
PROFESSOR_EMAIL="professor@jgfit.com"

# --- Supabase ---------------------------------------------------------
# Encontrados no painel do Supabase: Project Settings > Database / API
# Connection string (Transaction pooler — porta 6543) usada em runtime:
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connection string direta (porta 5432) usada para migrations:
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres"

SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_ANON_KEY=""        # chave publica (front)
SUPABASE_SERVICE_ROLE_KEY="" # chave secreta (backend) — NUNCA expor no front
SUPABASE_JWT_SECRET=""       # Project Settings > API > JWT Secret (valida os tokens)

# --- OpenAI (motor de personas) --------------------------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Storage ----------------------------------------------------------
SUPABASE_PHOTOS_BUCKET="evolution-photos"
