// JG-FIT — modelo de dados do backend
// Single-tenant por enquanto (1 personal). `tenantId` ja existe (nullable) para
// virar white-label multi-tenant no futuro sem reescrever o schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexao pooled (pgbouncer) — runtime
  directUrl = env("DIRECT_URL")   // conexao direta — migrations
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  PROFESSOR
  ALUNO
}

enum Sex {
  MASCULINO
  FEMININO
  OUTRO
}

enum Goal {
  HIPERTROFIA
  EMAGRECIMENTO
  CONDICIONAMENTO
  FORCA
  SAUDE
  REABILITACAO
}

enum DayOfWeek {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

enum ScheduleType {
  TREINO
  CARDIO
  DESCANSO
}

enum PhotoAngle {
  FRENTE
  LADO
  COSTAS
}

enum StudentStatus {
  PENDING
  APPROVED
  ONBOARDED
  REJECTED
}

enum TrainingExperience {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

// ----------------------------------------------------------------------------
// Usuarios & alunos
// ----------------------------------------------------------------------------

// Espelha o usuario do Supabase Auth (mesmo id).
model User {
  id        String   @id // = auth.users.id (uuid do Supabase)
  email     String   @unique
  name      String?
  role      Role     @default(ALUNO)
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       Student?
  chatMessages  ChatMessage[]  @relation("ChatFromUser")
  notifications Notification[]
}

model Student {
  id              String        @id @default(uuid())
  userId          String?       @unique // login do aluno (Supabase Auth)
  tenantId        String?
  name            String
  status          StudentStatus @default(PENDING) // Controle de fluxo de entrada
  approvedAt      DateTime?
  
  // -- Bloco 1: Biometria
  birthdate       DateTime?
  sex             Sex?
  heightCm        Float?
  weightKg        Float?
  bodyFatPct      Float?
  
  // -- Bloco 2: Objetivos e Experiencia
  goal               Goal?
  goalDeadline       String?       // ex: "3 meses", "ate dezembro"
  trainingExperience TrainingExperience?
  trainingTime       String?       // ex: "1 ano", "nunca treinou"
  
  // -- Bloco 3: Disponibilidade
  weeklyFrequency    Int?          // ex: 5 (dias por semana)
  sessionMinutes     Int?          // ex: 60 (minutos por sessao)
  preferredTime      String?       // ex: "Manha", "Noite"
  availableDays      Json?         // ex: ["SEG", "TER", "QUI"]
  
  // -- Bloco 4: Local e Equipamentos
  trainingLocation String?      // ex: "Academia", "Casa"
  equipment        String?      // ex: "Halteres, elastico" (se em casa)
  
  // -- Bloco 5: Saude e Estilo de vida
  injuries         String?      // ex: "Condromalacia no joelho direito"
  healthConditions String?      // ex: "Hipertensao controlada"
  profession       String?      // ex: "Programador (sedentario)"
  sleepHours       Float?       // ex: 7.5
  preferences      Json?        // ex: ["Musculacao", "Crossfit"]
  
  notes           String?
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  workouts        Workout[]
  periodizations  Periodization[]
  scheduleItems   WeeklyScheduleItem[]
  assessments     Assessment[]
  measurements    Measurement[]
  photos          ProgressPhoto[]
  workoutLogs     WorkoutLog[]
  chatMessages    ChatMessage[]
  personaMatch    PersonaMatch?
  dietPlan        DietPlan?
  subscription    Subscription?
  notifications   Notification[]

  @@index([tenantId])
}

// ----------------------------------------------------------------------------
// Exercicios & treinos
// ----------------------------------------------------------------------------

model Exercise {
  id           String   @id @default(uuid())
  tenantId     String?
  name         String
  muscleGroup  String?
  videoUrl     String?
  instructions String?
  createdAt    DateTime @default(now())

  workoutExercises WorkoutExercise[]

  @@index([tenantId])
}

model Workout {
  id              String   @id @default(uuid())
  tenantId        String?
  name            String
  label           String? // "A", "B", "C"...
  isTemplate      Boolean  @default(false)
  studentId       String?
  periodizationId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student       Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  periodization Periodization?     @relation(fields: [periodizationId], references: [id], onDelete: SetNull)
  exercises     WorkoutExercise[]
  scheduleItems WeeklyScheduleItem[]
  logs          WorkoutLog[]

  @@index([studentId])
  @@index([tenantId])
}

model WorkoutExercise {
  id         String  @id @default(uuid())
  workoutId  String
  exerciseId String
  order      Int     @default(0)
  sets       Int?
  reps       String? // "8-12", "10", "ate a falha"
  loadKg     Float?
  restSec    Int?
  notes      String?

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([workoutId])
}

model Periodization {
  id        String    @id @default(uuid())
  tenantId  String?
  studentId String
  name      String
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workouts Workout[]

  @@index([studentId])
}

model WeeklyScheduleItem {
  id        String       @id @default(uuid())
  studentId String
  dayOfWeek DayOfWeek
  type      ScheduleType @default(DESCANSO)
  workoutId String?
  notes     String?

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workout Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@unique([studentId, dayOfWeek])
}

// ----------------------------------------------------------------------------
// Avaliacoes & evolucao
// ----------------------------------------------------------------------------

model Assessment {
  id             String   @id @default(uuid())
  studentId      String
  date           DateTime @default(now())
  weightKg       Float?
  bodyFatPct     Float?
  circumferences Json? // { braco: 38, cintura: 80, ... }
  notes          String?
  createdAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Measurement {
  id         String   @id @default(uuid())
  studentId  String
  date       DateTime @default(now())
  weightKg   Float?
  bodyFatPct Float?
  extra      Json?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model ProgressPhoto {
  id          String      @id @default(uuid())
  studentId   String
  date        DateTime    @default(now())
  storagePath String // path no bucket do Supabase Storage
  angle       PhotoAngle?
  createdAt   DateTime    @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ----------------------------------------------------------------------------
// Logs de treino (assiduidade / adesao)
// ----------------------------------------------------------------------------

model WorkoutLog {
  id        String   @id @default(uuid())
  studentId String
  workoutId String?
  date      DateTime @default(now())
  loadsUsed Json? // { exerciseId: loadKg, ... }
  completed Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  workout Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@index([studentId])
}

// ----------------------------------------------------------------------------
// Chat aluno <-> professor
// ----------------------------------------------------------------------------

model ChatMessage {
  id         String    @id @default(uuid())
  studentId  String // conversa pertence a este aluno
  fromUserId String
  body       String
  sentAt     DateTime  @default(now())
  readAt     DateTime?

  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromUser User    @relation("ChatFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ----------------------------------------------------------------------------
// Motor de Personas (cache do resultado da IA)
// ----------------------------------------------------------------------------

model PersonaMatch {
  id         String   @id @default(uuid())
  studentId  String   @unique
  results    Json // [{ matchStudentId, score, reasons }]
  computedAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Round 3 — Nutrição, Assinaturas e Notificações
// ----------------------------------------------------------------------------

enum SubscriptionStatus {
  ACTIVE
  OVERDUE
  CANCELED
}

enum NotificationType {
  GERAL
  TREINO
  PAGAMENTO
  AVALIACAO
  MENSAGEM
}

// Plano alimentar / metas de nutrição do aluno (1 por aluno).
model DietPlan {
  id          String   @id @default(uuid())
  studentId   String   @unique
  calories    Int?
  protein     Float? // gramas
  carbs       Float? // gramas
  fat         Float? // gramas
  waterLiters Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// Assinatura / mensalidade do aluno (1 por aluno).
model Subscription {
  id        String             @id @default(uuid())
  studentId String             @unique
  status    SubscriptionStatus @default(ACTIVE)
  planName  String?
  dueDate   DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// Notificação destinada a um usuário (User) e/ou aluno (Student).
model Notification {
  id        String           @id @default(uuid())
  userId    String?
  studentId String?
  title     String
  message   String
  type      NotificationType @default(GERAL)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studentId])
}
